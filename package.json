{
  "name": "rulopass",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "make-exe": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.rulopass.app",
    "productName": "RuloPass",
    "icon": "public/icon.ico",
    "directories": {
      "output": "release-build"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "public/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": ["**/*"]
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "vite": "^8.0.9",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sudo-prompt": "^9.2.1"
  }
}
